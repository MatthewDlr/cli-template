{
  "name": "template-cli",
  "version": "0.1.0",
  "private": true,
  "description": "A CLI tool to supercharge developer experience",
  "bin": {
    "cli": "./cli.ts"
  },
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun --watch cli.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile --minify --bytecode template-cli",
    "test": "bun test --coverage",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "eslint-plugin-neverthrow": "^1.1.4",
    "neverthrow": "^8.2.0",
    "picocolors": "^1.1.1",
    "terminal-link": "^5.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "^7.0.0-dev.20260429.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
